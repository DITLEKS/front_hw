# токен GigaChat API можно получить на https://developers.sber.ru/gigachat
# Передаётся через переменные окружения

# Базовый URL сервера (для локальной разработки)
REACT_APP_API_BASE_URL=http://localhost:3002

# Авторизационные данные GigaChat (Base64 от ClientId:ClientSecret)
GIGACHAT_AUTH_KEY=your_base64_encoded_credentials_here

# Скоуп доступа к API
GIGACHAT_SCOPE=GIGACHAT_API_PERS
