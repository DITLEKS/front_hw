# Базовый URL GigaChat API (для локальной разработки)
REACT_APP_API_BASE_URL=http://localhost:3002

# Для продакшна (Railway, Vercel и т.п.)
# REACT_APP_API_BASE_URL=https://your-server.railway.app

# OAuth‑учётные данные (Base64 от client_id:client_secret)
GIGACHAT_TOKEN=your_base64_client_id_and_secret_here
