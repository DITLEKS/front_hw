# ── Переменная для Express-сервера (server.js) ─────────────────────────────
# Base64-строка вида ClientId:ClientSecret от личного кабинета GigaChat
# Получить: https://developers.sber.ru/gigachat → «Мои проекты» → API ключи
GIGACHAT_TOKEN=your_base64_client_id_and_secret_here

# ── Переменная для React-приложения (фронтенд) ────────────────────────────
# URL задеплоенного server.js (Railway даст вам эту ссылку после деплоя)
# Для локальной разработки: http://localhost:3002
REACT_APP_API_BASE_URL=https://your-server.railway.app
