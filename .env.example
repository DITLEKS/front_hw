# Environment Variables for GigaChat Integration

# GigaChat API Base URL (for local development)
REACT_APP_API_BASE_URL=http://localhost:3002

# For production (Railway, Vercel, etc.)
# REACT_APP_API_BASE_URL=https://your-server.railway.app

# OAuth Credentials (Base64 encoded client_id:client_secret)
GIGACHAT_TOKEN=your_base64_client_id_and_secret_here

# Note: For production, use secure environment variables and never commit secrets to repository.
